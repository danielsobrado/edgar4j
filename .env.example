# Edgar4j Environment Configuration
# Copy this file to .env and update the values

# ===================
# MongoDB Configuration
# ===================
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin123

# ===================
# Application Configuration
# ===================
SPRING_PROFILES_ACTIVE=docker

# SEC API Configuration
# IMPORTANT: Use a real company/app identifier and a real monitored contact email.
# Do not use example.com or noreply addresses.
SEC_USER_AGENT=Your Company Name sec-ops@your-company.com
MONGO_URL=mongodb://localhost:27017/edgar
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/edgar4j
SPRING_DATASOURCE_USERNAME=edgar4j
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
EDGAR4J_SECURITY_ENABLED=false
EDGAR4J_SECURITY_USERNAME=
EDGAR4J_SECURITY_PASSWORD=

# ===================
# Frontend Configuration
# ===================
VITE_API_URL=http://localhost:8080

# ===================
# Market Data Providers
# ===================
# TIINGO_API_TOKEN=
# FINNHUB_API_KEY=
# ALPHA_VANTAGE_API_KEY=

# ===================
# Mongo Express (Development)
# ===================
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin123

# ===================
# Optional: External Services
# ===================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# ELASTICSEARCH_URL=http://localhost:9200
